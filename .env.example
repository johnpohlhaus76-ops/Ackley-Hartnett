# Optional: enables the satellite Google Maps view on /map.
# Without it, the map falls back to a built-in projected world map (no key required).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Enables the "Ask AH" AI assistant (floating chat) on the public site.
# Without it, the assistant politely directs visitors to phone/email.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Enables the live HubSpot CRM in the portal (/portal/crm).
# Create a HubSpot Private App with crm.objects.{companies,contacts,deals} read+write
# scopes and paste its access token here. Without it, the portal shows setup steps.
HUBSPOT_ACCESS_TOKEN=
